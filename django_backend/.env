# Django runtime
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=0.0.0.0,localhost,127.0.0.1
DJANGO_PORT=8081

# Authentication
AUTH_PASSWORD=secret
TOKEN_EXPIRY_SECONDS=360000

# Upload limits (bytes)
UPLOAD_MAX_BYTES=5242880
MAX_OFFICE_UNCOMPRESSED_SIZE=20971520
MAX_OFFICE_ARCHIVE_ENTRIES=2000

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8082,http://127.0.0.1:8082
CSRF_TRUSTED_ORIGINS=http://localhost:8082,http://127.0.0.1:8082
CORS_ALLOW_CREDENTIALS=False

# SSE stream hardening
SSE_IDLE_TIMEOUT_MS=30000
SSE_MAX_RETRIES=1
SSE_BUFFER_LIMIT_BYTES=1048576

# Rate limit
RATE_LIMIT_MAX=5000
RATE_LIMIT_INTERVAL=60

# Cache
CACHE_MAX_SIZE=200
CACHE_EXPIRY=300

# Provider API keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
SILICONFLOW_API_KEY=
BOCHA_API_KEY=
